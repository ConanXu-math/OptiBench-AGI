# OptiBench-AGI 环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env

# ========== LLM 配置 ==========
# 提供商: openai | openai-like | ollama | anthropic | google
# ollama = 本地 Ollama（如 qwen2.5:7b），无需 API Key
OPTIBENCH_PROVIDER=openai
# 模型 ID（openai: gpt-4o；ollama: qwen2.5:7b 等）
OPTIBENCH_MODEL=gpt-4o
# 自定义 API 端点（openai-like 必填；ollama 可选，默认 http://localhost:11434/v1）
OPTIBENCH_BASE_URL=
# API Key（ollama 不需要；未设时可能回退到各厂商的默认环境变量）
OPTIBENCH_API_KEY=

# ========== 代理（可选） ==========
# 无法直连 arXiv/外网时填写，requests 等会自动使用。示例: http://127.0.0.1:7890
HTTP_PROXY=
HTTPS_PROXY=

# ========== arXiv API（搜索/下载） ==========
# 若出现 "Requesting page... try 0/1/2/3" 后一直超时，可配置上面代理后重试。
# 诊断脚本: python scripts/diagnose_arxiv_connection.py
#
OPTIBENCH_ARXIV_TIMEOUT=120
OPTIBENCH_ARXIV_BASE_URL=

# ========== 超时与路径 ==========
# PDF 转换：Marker 超时（秒）
OPTIBENCH_MARKER_TIMEOUT=300
# PDF 转换：Nougat 超时（秒）
OPTIBENCH_NOUGAT_TIMEOUT=300
# Python 验证超时（秒）
OPTIBENCH_PY_TIMEOUT=120
# Lean 验证超时（秒）
OPTIBENCH_LEAN_TIMEOUT=300
# Lean 项目目录（用于 Lean 验证）
OPTIBENCH_LEAN_PROJECT_DIR=

# 提取最大字符数
OPTIBENCH_EXTRACT_MAX_CHARS=24000
  

